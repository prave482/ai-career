# MongoDB Atlas or local Mongo URI. Optional: if omitted, the app uses in-memory storage.
MONGODB_URI=

# OpenAI API key. Optional if you prefer LLAMA or fallback rules.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional Gemini configuration.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional OpenAI-compatible LLAMA endpoint configuration.
LLAMA_API_URL=
LLAMA_API_KEY=
LLAMA_MODEL=llama-3.1-70b-instruct

# Server port
PORT=5000

# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000
